# ── Application ──────────────────────────────────────────────
APP_NAME=Verken Orders Dashboard
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
PORT=8000

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Falabella Seller Center ───────────────────────────────────
FALABELLA_USER_ID=your_email@domain.com
FALABELLA_API_KEY=your_hmac_api_key
FALABELLA_BASE_URL=https://sellercenter-api.falabella.com

# ── Mercado Libre ─────────────────────────────────────────────
MERCADOLIBRE_CLIENT_ID=your_app_id
MERCADOLIBRE_CLIENT_SECRET=your_client_secret
MERCADOLIBRE_ACCESS_TOKEN=your_oauth_access_token
MERCADOLIBRE_SELLER_ID=your_numeric_seller_id

# ── Email / Resend ────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=Verken Orders <orders@yourdomain.com>
EMAIL_RECIPIENTS=admin@yourdomain.com

# ── Scheduler ────────────────────────────────────────────────
DAILY_SYNC_HOUR=7
DAILY_SYNC_MINUTE=0
SCHEDULER_TIMEZONE=America/Santiago

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
